#!/bin/bash

# omarchy:summary=Launch a URL as a web app in the default supported browser
# omarchy:args=<url>

browser=$(xdg-settings get default-web-browser)
url=$1
webapp_name=${2:-}

case $browser in
google-chrome* | brave* | microsoft-edge* | opera* | vivaldi* | helium*)
  exec setsid uwsm-app -- $(sed -n 's/^Exec=\([^ ]*\).*/\1/p' {~/.local,~/.nix-profile,/usr}/share/applications/$browser 2>/dev/null | head -1) --app="$url" "${@:3}"
  ;;
firefox*)
  if [ -n "$webapp_name" ]; then
    for dir in {~/.local,~/.nix-profile,/usr}/share/applications; do
      desktop_file="${dir/#\~/$HOME}/${webapp_name}.desktop"
      if [ -f "$desktop_file" ]; then
        exec setsid uwsm-app -- "$desktop_file" "${@:3}"
      fi
    done
  fi
  exec setsid uwsm-app -- firefox "$url" "${@:3}"
  ;;
*)
  browser="chromium.desktop"
  exec setsid uwsm-app -- $(sed -n 's/^Exec=\([^ ]*\).*/\1/p' {~/.local,~/.nix-profile,/usr}/share/applications/$browser 2>/dev/null | head -1) --app="$url" "${@:3}"
  ;;
esac
