#!/bin/bash

# Add the named packages to the system from the AUR if they're missing. Returns false if it couldn't be done.

ensure_yay() {
  if omarchy-cmd-present yay; then
    return 0
  fi

  omarchy-pkg-add base-devel git || return 1

  build_dir=$(mktemp -d)
  if [[ -z $build_dir ]]; then
    return 1
  fi

  if ! git clone --depth 1 https://aur.archlinux.org/yay.git "$build_dir/yay"; then
    rm -rf "$build_dir"
    return 1
  fi

  if ! pushd "$build_dir/yay" >/dev/null; then
    rm -rf "$build_dir"
    return 1
  fi

  if ! makepkg -si --noconfirm --needed; then
    popd >/dev/null || true
    rm -rf "$build_dir"
    return 1
  fi

  popd >/dev/null || true
  rm -rf "$build_dir"

  omarchy-cmd-present yay
}

if omarchy-pkg-missing "$@"; then
  ensure_yay || exit 1
  yay -S --noconfirm --needed --sudoflags '-n' "$@" || exit 1
fi

for pkg in "$@"; do
  # Secondary check to handle states where pacman doesn't actually register an error
  if ! pacman -Q "$pkg" &>/dev/null; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
