#!/bin/bash

# omarchy:summary=Launch Walker and ensure its Elephant data provider is running

if ! pgrep -x elephant > /dev/null; then
  setsid uwsm-app -- elephant &
fi

# Ensure walker service is running
if ! pgrep -f "walker --gapplication-service" > /dev/null; then
  setsid uwsm-app -- env GSK_RENDERER=cairo walker --gapplication-service &
fi

WALKER_THEME=$(grep 'theme = ' "$HOME/.config/walker/config.toml" | sed 's/.*=\s* "\(.*\)".*/\1/')

WIDTH=644
[[ "$WALKER_THEME" == "dotfiles" ]] && WIDTH=300

exec walker --width "$WIDTH" --maxheight 300 --minheight 300 "$@"
