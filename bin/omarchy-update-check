#!/bin/bash

_checkCommandExists() {
    cmd="$1"
    if ! command -v "$cmd" >/dev/null; then
        echo 1
        return
    fi
    echo 0
    return
}
script_name=$(basename "$0")
instance_count=$(ps aux | grep -F "$script_name" | grep -v grep | grep -v $$ | wc -l)
if [ $instance_count -gt 1 ]; then
    sleep $instance_count
fi

threshhold_green=0
threshhold_yellow=25
threshhold_red=100

if [[ $(_checkCommandExists "pacman") == 0 ]]; then
    aur_helper="paru"
    check_lock_files() {
        local pacman_lock="/var/lib/pacman/db.lck"
        local checkup_lock="${TMPDIR:-/tmp}/checkup-db-${UID}/db.lck"
        while [ -f "$pacman_lock" ] || [ -f "$checkup_lock" ]; do
            sleep 1
        done
    }
    check_lock_files

    checkupdates_out=$(checkupdates 2>/dev/null)
    if [ -n "$checkupdates_out" ]; then
        official_updates=$(printf '%s\n' "$checkupdates_out" | wc -l)
    else
        official_updates=0
    fi

    aur_updates=0
    paru_out=""
    yay_out=""
    if command -v paru >/dev/null 2>&1; then
        paru_out=$(paru -Qua 2>/dev/null)
        if [ -n "$paru_out" ]; then
            aur_updates=$(printf '%s\n' "$paru_out" | wc -l)
        fi
    elif command -v yay >/dev/null 2>&1; then
        yay_out=$(yay -Qua 2>/dev/null)
        if [ -n "$yay_out" ]; then
            aur_updates=$(printf '%s\n' "$yay_out" | wc -l)
        fi
    fi

    updates=$((official_updates + aur_updates))
else
    updates=0
fi

css_class="green"
    if [ "$updates" -gt $threshhold_yellow ]; then
        css_class="yellow"
    fi

    if [ "$updates" -gt $threshhold_red ]; then
        css_class="red"
    fi

    if [ "$updates" != 0 ]; then
        if [ "$updates" -gt $threshhold_green ]; then
            # Build tooltip from available outputs, escape quotes and newlines for JSON
            tooltip_body=""
            if [ "$official_updates" -gt 0 ]; then
                esc_official=$(printf '%s' "$checkupdates_out" | sed 's/"/\\"/g' | sed ':a;N;$!ba;s/\n/\\n/g')
                tooltip_body="Official updates:\n${esc_official}"
            fi
            if [ "$aur_updates" -gt 0 ]; then
                if [ -n "$paru_out" ]; then
                    esc_aur=$(printf '%s' "$paru_out" | sed 's/"/\\"/g' | sed ':a;N;$!ba;s/\n/\\n/g')
                elif [ -n "$yay_out" ]; then
                    esc_aur=$(printf '%s' "$yay_out" | sed 's/"/\\"/g' | sed ':a;N;$!ba;s/\n/\\n/g')
                else
                    esc_aur=""
                fi
                if [ -n "$esc_aur" ]; then
                    if [ -n "$tooltip_body" ]; then
                        tooltip_body="$tooltip_body\n\nAUR updates:\n${esc_aur}"
                    else
                        tooltip_body="AUR updates:\n${esc_aur}"
                    fi
                fi
            fi

            # Fallback if tooltip_body empty for some reason
            if [ -z "$tooltip_body" ]; then
                tooltip_body="Updates available"
            fi

            printf '{"text": "%s", "alt": "%s", "tooltip": "%s", "class": "%s"}' "$updates" "$updates" "$tooltip_body" "$css_class"
        else
            printf '{"text": "0", "alt": "0", "tooltip": "No updates available", "class": "green"}'
        fi
    fi
